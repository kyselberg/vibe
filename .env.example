NUXT_APP_PASSCODE=vibe-player
NUXT_SESSION_SECRET=replace-this-secret

# Neon PostgreSQL connection string (required for production)
# Get this from https://console.neon.tech/
DATABASE_URL=postgresql://user:password@hostname/database

# Cloudflare R2 storage (required for media uploads and streaming)
# Create an R2 bucket and API token at https://dash.cloudflare.com/
CLOUDFLARE_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_BUCKET=your-bucket-name
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_REGION=auto
